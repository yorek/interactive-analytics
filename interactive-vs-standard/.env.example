# Copy to .env and adjust for your Snowflake account.
# Benchmark target database/schema (used by iwtest.py and spcs/scripts/run-benchmark-spcs.sh)
BENCH_DATABASE=DMAURI_PLAYGROUND
BENCH_SCHEMA=ZUTEST
BENCH_SEED=42

# Warehouses for --compare and single-warehouse runs
BENCH_STANDARD_WAREHOUSE=DM_STANDARD
BENCH_INTERACTIVE_WAREHOUSE=DM_INTERACTIVE

# OAuth bootstrap warehouse inside SPCS (row counts, preload, etc.)
BENCH_BOOTSTRAP_WAREHOUSE=DM_STANDARD
